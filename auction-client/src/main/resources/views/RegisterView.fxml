<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bidhub.client.controller.RegisterController" styleClass="main-container">

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label text="📝 Đăng Ký Tài Khoản" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="Tham gia cộng đồng BidHub ngay hôm nay" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

    <VBox spacing="10" maxWidth="300" alignment="CENTER_LEFT">
        <Label text="Tên đăng nhập:" />
        <TextField fx:id="txtUsername" promptText="Nhập username..." />

        <Label text="Email:" />
        <TextField fx:id="txtEmail" promptText="Nhập địa chỉ email..." />

        <Label text="Vai trò tham gia:" />
        <ComboBox fx:id="cbRole" prefWidth="300" />

        <Label text="Mật khẩu:" />
        <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu..." />

        <Label text="Xác nhận mật khẩu:" />
        <PasswordField fx:id="txtConfirmPassword" promptText="Nhập lại mật khẩu..." />
    </VBox>

    <Label fx:id="lblError" textFill="RED" />

    <Button text="✨ TẠO TÀI KHOẢN" defaultButton="true" onAction="#handleRegister"
            prefWidth="300" style="-fx-font-size: 14px; -fx-padding: 10px; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Hyperlink text="⬅ Đã có tài khoản? Quay lại đăng nhập" onAction="#switchToLogin"/>
</VBox>

