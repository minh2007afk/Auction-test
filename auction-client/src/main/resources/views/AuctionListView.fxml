<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidhub.client.controller.AuctionListController"
            styleClass="main-container" prefWidth="800" prefHeight="600">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15px 20px;">
            <Label text="🏦 BidHub" style="-fx-font-size: 22px; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS" />

            <Button text="Đăng xuất" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20px;">
            <Label text="Sàn Đấu Giá Trực Tuyến" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <Label text="Nhấn đúp vào một sản phẩm để xem chi tiết hoặc đặt giá" style="-fx-text-fill: #7f8c8d;"/>

            <TableView fx:id="tableAuctions" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
                <columns>
                    <TableColumn fx:id="colName" text="Sản Phẩm" prefWidth="400" />
                    <TableColumn fx:id="colPrice" text="Giá Hiện Tại" prefWidth="180" />
                    <TableColumn fx:id="colStatus" text="Trạng Thái" prefWidth="150" />
                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

</BorderPane>